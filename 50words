];

const list = document.getElementById("list");
words.forEach(item=>{
  const div=document.createElement("div");
  div.className="word";
  div.innerHTML=`<div class="title">${item.word}</div><div>${item.def}</div>`;
  list.appendChild(div);
});
</script>

</body>
</html>
