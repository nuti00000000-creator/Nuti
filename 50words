<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>50 слов и их объяснения</title>
  <style>
    body { font-family: Arial, sans-serif; background:#f5f5f5; padding:20px; }
    h1 { text-align:center; }
    .word { background:white; margin:10px 0; padding:15px; border-radius:10px; box-shadow:0 2px 5px rgba(0,0,0,0.1); }
    .title { font-weight:bold; font-size:18px; }
  </style>
</head>
<body>
<h1>50 слов и их объяснения</h1>
<div id="list"></div>

<script>
const words = [
  {word:"Карик адам",def:"очень жадный человек (жмот)"},
  {word:"Салакалуу боз бала",def:"начитанный, образованный молодой человек, которого приятно слушать"},
  {word:"Керденкештик кылуу",def:"упрямиться, не слушать советов"},
  {word:"Куш уйку",def:"кратковременный сон, дремота"},
  {word:"Зикири кагылуу",def:"удовлетворение от завершения сложной работы (гора с плеч)"},
  {word:"Ажыл",def:"работа, труд"},
  {word:"Кийиз китеп",def:"войлочная книга (идиома)"},
  {word:"Кайыр",def:"благо, добро"},
  {word:"Ырдам",def:"помощь"},
  {word:"Кыса",def:"рассказ, повествование"},
  {word:"Актык кагаз",def:"оправдательный документ"},
  {word:"Атан",def:"кастрированный верблюд"},
  {word:"Кысрак",def:"кобыла"},
  {word:"Өплен",def:"маленькое животное, подобное мыши"},
  {word:"Тытыр",def:"верблюдица"},
  {word:"Кылгыр",def:"акылдуу, тапкыч (эски сөз)"},
  {word:"Бөксө",def:"төмөн, пасты жер"},
  {word:"Зоболо",def:"даража, абал"},
  {word:"Шөкөт",def:"кооздук, жасалга"},
  {word:"Аласалуу",def:"төмөн, басаң абал"},
  {word:"Тумчукма",def:"басылып калган абал"},
  {word:"Ымала",def:"ынтымак, жарашуу"},
  {word:"Келбет",def:"сырткы көрүнүш"},
  {word:"Сөлөкөт",def:"элес, көрүнүш"},
  {word:"Дабыш",def:"үн, кабар"},
