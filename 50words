  {word:"Жорго",def:"конь с плавной походкой"},
  {word:"Көк жал",def:"образ храброго, сильного человека"},
  {word:"Түнөк",def:"место для ночёвки"},
  {word:"Жайыт",def:"пастбище"},
  {word:"Сай",def:"небольшая долина"},
  {word:"Кыл аркан",def:"тонкая прочная верёвка"},
  {word:"Сөөк",def:"род, происхождение"},
  {word:"Байге",def:"награда за соревнования"},
  {word:"Чоролоо",def:"поход, экспедиция"},
  {word:"Топо",def:"маленький холм"},
  {word:"Тасма",def:"пояс"},
  {word:"Сылан",def:"украшение"},
  {word:"Сарык",def:"старое название овцы"},
  {word:"Жайсаң",def:"знатный, уважаемый"},
